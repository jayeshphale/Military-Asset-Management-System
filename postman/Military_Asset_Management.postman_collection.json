  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set base URL for different environments",
          "pm.collectionVariables.set('base_url', 'http://localhost:5000/api');",
          "",
          "// For production, uncomment the line below:",
          "// pm.collectionVariables.set('base_url', 'https://your-production-url.com/api');"
